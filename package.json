{
  "name": "modoo-todo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint .",
    "functions:build": "npm --prefix functions run build",
    "emulators": "firebase emulators:start --only auth,firestore,storage,functions,hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:functions": "npm --prefix functions run build && firebase deploy --only functions"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "firebase": "^12.0.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.4"
  }
}
