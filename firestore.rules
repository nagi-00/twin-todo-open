rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email in [
          "mx.gin.xo@gmail.com",
          "1995dianalee@gmail.com"
        ];
    }

    function hasBackgroundEntitlement(uid) {
      return isAdmin()
        || (exists(/databases/$(database)/documents/entitlements/$(uid))
          && get(/databases/$(database)/documents/entitlements/$(uid)).data.backgroundImageUnlocked == true);
    }

    function pairExists(pairId) {
      return exists(/databases/$(database)/documents/pairs/$(pairId));
    }

    function pairData(pairId) {
      return get(/databases/$(database)/documents/pairs/$(pairId)).data;
    }

    function isPairMember(pairId) {
      return signedIn()
        && pairExists(pairId)
        && pairData(pairId).members.hasAny([request.auth.uid])
        && pairData(pairId).status == "active";
    }

    function isPairMemberResource() {
      return signedIn()
        && resource.data.members.hasAny([request.auth.uid])
        && resource.data.status == "active";
    }

    function validCategoryKey(value) {
      return value in ["required", "growth", "freedom"];
    }

    function validTodoStatus(value) {
      return value in ["open", "done", "archived"];
    }

    function validTodoTitle(value) {
      return value is string && value.size() >= 1 && value.size() <= 1000;
    }

    function validCategoryLabel(value) {
      return value is string && value.size() >= 1 && value.size() <= 12;
    }

    function validHexColor(value) {
      return value is string
        && value.size() == 7
        && value.matches("^#[0-9a-fA-F]{6}$");
    }

    function validCategorySettings() {
      return request.resource.data.keys().hasOnly([
          "required",
          "growth",
          "freedom",
          "updatedBy",
          "updatedAt"
        ])
        && request.resource.data.updatedBy == request.auth.uid
        && validCategoryLabel(request.resource.data.required)
        && validCategoryLabel(request.resource.data.growth)
        && validCategoryLabel(request.resource.data.freedom);
    }

    function validTodoCreate(ownerUid) {
      return request.resource.data.ownerUid == ownerUid
        && validCategoryKey(request.resource.data.categoryKey)
        && validTodoTitle(request.resource.data.title)
        && request.resource.data.status == "open"
        && (!("state" in request.resource.data) || request.resource.data.state in [0, 1, 2])
        && (!("hidden" in request.resource.data) || request.resource.data.hidden is bool)
        && (!("important" in request.resource.data) || request.resource.data.important is bool)
        && (!("memo" in request.resource.data) || (request.resource.data.memo is string && request.resource.data.memo.size() <= 500))
        && (!("position" in request.resource.data) || request.resource.data.position is number);
    }

    function validTodoUpdate() {
      return request.resource.data.ownerUid == resource.data.ownerUid
        && validCategoryKey(request.resource.data.categoryKey)
        && validTodoTitle(request.resource.data.title)
        && validTodoStatus(request.resource.data.status)
        && (!("state" in request.resource.data) || request.resource.data.state in [0, 1, 2])
        && (!("hidden" in request.resource.data) || request.resource.data.hidden is bool)
        && (!("important" in request.resource.data) || request.resource.data.important is bool)
        && (!("memo" in request.resource.data) || (request.resource.data.memo is string && request.resource.data.memo.size() <= 500))
        && (!("position" in request.resource.data) || request.resource.data.position is number);
    }

    match /users/{uid} {
      allow create: if isSelf(uid)
        && request.resource.data.keys().hasOnly([
          "email",
          "emailVerified",
          "displayName",
          "nickname",
          "nicknameNormalized",
          "avatarPath",
          "backgroundPath",
          "backgroundOpacity",
          "defaultThemeColor",
          "role",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.emailVerified == request.auth.token.email_verified
        && request.resource.data.emailVerified is bool
        && request.resource.data.role == "user"
        && request.resource.data.nickname == null
        && request.resource.data.nicknameNormalized == null;

      allow read: if isSelf(uid);

      allow update: if isSelf(uid)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "displayName",
          "avatarPath",
          "backgroundPath",
          "backgroundOpacity",
          "defaultThemeColor",
          "updatedAt"
        ])
        && (!request.resource.data.diff(resource.data).changedKeys().hasAny([
          "backgroundPath",
          "backgroundOpacity"
        ]) || hasBackgroundEntitlement(uid))
        && (!("backgroundOpacity" in request.resource.data)
          || (request.resource.data.backgroundOpacity is number
            && request.resource.data.backgroundOpacity >= 0
            && request.resource.data.backgroundOpacity <= 0.7))
        && (!("defaultThemeColor" in request.resource.data)
          || validHexColor(request.resource.data.defaultThemeColor));

      allow delete: if false;

      match /todos/{todoId} {
        allow read: if isSelf(uid);
        allow create: if isSelf(uid) && validTodoCreate(uid);
        allow update: if isSelf(uid) && validTodoUpdate();
        allow delete: if false;
      }

      match /settings/categories {
        allow read: if isSelf(uid);
        allow create, update: if isSelf(uid) && validCategorySettings();
        allow delete: if false;
      }

      match /journal/{date} {
        allow read, create, update: if isSelf(uid);
        allow delete: if false;
      }

      match /notes/{date} {
        allow read, create, update: if isSelf(uid);
        allow delete: if false;
      }

      match /routines/{routineId} {
        allow read, create, update: if isSelf(uid);
        allow delete: if isSelf(uid);
      }

      match /dateColors/{date} {
        allow read, create, update: if isSelf(uid);
        allow delete: if isSelf(uid);
      }

      match /messages/{date} {
        allow read, create, update: if isSelf(uid);
        allow delete: if false;
      }

      match /daily/{date} {
        allow read, create, update: if isSelf(uid);
        allow delete: if false;
      }

      match /shared/{date} {
        allow read, create, update: if isSelf(uid);
        allow delete: if false;
      }
    }

    match /entitlements/{uid} {
      allow read: if isSelf(uid);
      allow create, update, delete: if false;
    }

    match /usageDaily/{usageId} {
      allow read, write: if false;
    }

    match /uploadTickets/{uid}/kinds/{kind} {
      allow read, write: if false;
    }

    match /nicknames/{nicknameNormalized} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    match /pairRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);

      allow create, update, delete: if false;
    }

    match /pairs/{pairId} {
      allow read: if isPairMemberResource();
      allow create, update, delete: if false;

      match /todos/{todoId} {
        allow read: if isPairMember(pairId);
        allow create: if isPairMember(pairId) && validTodoCreate(request.auth.uid);
        allow update: if isPairMember(pairId) && validTodoUpdate();
        allow delete: if false;
      }

      match /settings/categories {
        allow read: if isPairMember(pairId);
        allow create, update: if isPairMember(pairId) && validCategorySettings();
        allow delete: if false;
      }

      match /shared/{sharedId} {
        allow read: if isPairMember(pairId);
        allow create, update: if isPairMember(pairId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.date is string
          && request.resource.data.todos is list
          && request.resource.data.note is string
          && request.resource.data.color is string
          && request.resource.data.messages is list;
        allow delete: if false;
      }
    }

    match /auditLogs/{logId} {
      allow read, write: if false;
    }

    match /adminAuditLogs/{logId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
